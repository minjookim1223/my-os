module.exports = {"bio":{"full_name":"Jay Kim","first_name":"Jay","last_name":"Kim","alias":"Jay","description":"Software Engineer building backend services and real-time data platforms, with a background spanning data engineering, machine learning, and cloud infrastructure.","avatar_url":"https://github.com/minjookim1223.png","theme_color":"#3D3D3D","location":"San Francisco, CA","email":"minjookim1223@gmail.com","phone":"(949) 812-2206","links":{"github":"https://github.com/minjookim1223","linkedin":"https://www.linkedin.com/in/minjookim1223","instagram":"https://www.instagram.com/balancedcolumns/","resume":"https://jaymkim.com/resume.pdf"},"skills":{"Python":"Expert","SQL":"Advanced","Java":"Advanced","JavaScript/TypeScript":"Advanced","C++":"Intermediate"}},"awards":[],"educations":[{"key":"gatech-202408","name":"Georgia Institute of Technology","image":"static/media/gatech.e5ba5989.png","degree":"Master of Science, Computer Science","detail":"Specialization in Artificial Intelligence","location":"Atlanta, GA","links":"[gatech.edu](https://www.gatech.edu/)  \n[cc.gatech.edu](https://www.cc.gatech.edu/)"},{"key":"usc-201708","name":"University of Southern California","image":"static/media/usc.2b838c91.png","degree":"Bachelor of Science, Business Administration","detail":"Concentration in Data Science","location":"Los Angeles, CA","links":"[usc.edu](https://www.usc.edu/)  \n[marshall.usc.edu](https://www.marshall.usc.edu/)"},{"key":"ihs-201308","name":"Irvine High School","image":"static/media/ihs.71f898e7.png","degree":"High School Diploma","location":"Irvine, CA","link":"https://irvinehigh.iusd.org/"}],"projects":[],"workExperiences":[{"key":"qcells-202606","name":"Qcells","date":"June 2026 - Current","image":"static/media/qcells.e86b657c.png","position":"Software Engineer","team":"Data & Real-Time Intelligence","location":"San Francisco, CA","detail":"- Developed backend services to ingest and expose real-time telemetry data from battery storage and grid assets, enabling monitoring and control across the platform\n- Designed and implemented Peak Demand API pipeline for battery, integrating data ingestion, time-series processing, PostgreSQL storage, and REST endpoints to surface peak load events for grid and battery management workflows\n- Built and deployed containerized platform services on Azure using Docker and Kubernetes, standardizing deployment for grid and battery management components\n- Implemented CI/CD pipelines with GitHub Actions and Azure Monitor/Application Insights observability for platform services, reducing deployment time and cutting incident detection time by 60%"},{"key":"stealthstartup-202309","name":"Stealth Startup","date":"Sep. 2023 - Feb. 2025","image":"static/media/stealthstartup.f4c067bc.png","position":"Software Engineer","location":"Los Angeles, CA","detail":"- Led a start-up focused on streamlining the higher education process for international students by developing innovative solutions and tools that simplify applications, transfers, and enrollment workflows\n- Engineered a robust full-stack system using DRF (Python) and React (JavaScript), implementing a scalable student portfolio management pipeline and optimizing operational efficiency while seamlessly integrating the system across platforms\n- Developed and optimized back-testing engine (Python) to forecast student acceptance probabilities at targeted colleges, utilizing historical data and advanced algorithms to provide actionable insights for strategic application planning\n- Designed and structured the initial database using PostgreSQL to ensure efficient data handling, scalability, and performance, while implementing encryption and security protocols to protect sensitive information and ensure regulatory compliance"},{"key":"capitalone-202108","name":"Capital One","date":"Aug. 2021 - Aug. 2023","image":"static/media/capitalone.4da7e5c3.png","position":"Python Developer & Data Analyst","team":"Data Infrastructure, Analysis, and Engineering","location":"McLean, VA","detail":"- Built a full-stack application using React and Python/Django REST Framework that surfaced KPIs and statistical stability metrics across 20+ bank models, replacing recurring ad hoc analyst requests with standardized automated reporting\n- Engineered Apache Spark data pipelines that cleaned and transformed 100M+ rows of transaction data, reducing model execution time by 25% through targeted performance optimizations\n- Developed internal Python tools that automated transaction pattern analysis for digital asset monitoring workflows, accelerating AML alert reviews by 40%\n- Integrated the Holistic Risk Scoring Model into AML data pipelines and engineered predictive features from 3+ years of historical investigation outcomes, improving fraud alert escalation precision by 10%"},{"key":"franklintempleton-202006","name":"Franklin Templeton","date":"June 2020 - Aug. 2020","image":"static/media/franklintempleton.c9b2d5e5.png","icon":"static/media/franklintempleton.icon.7888d7c2.png","position":"Python Developer Intern","team":"Quantitative Investment Operations","location":"Pasadena, CA","detail":"- Developed a portfolio data management system and dashboard by integrating internal REST APIs with Snowflake to assess and track portfolio data for 200+ clients, increasing operational efficiency by 90%\n- Migrated Alteryx portfolio tracking workflows to reusable Python libraries, enabling identification of underperforming assets and allocation analysis across fixed-income strategies\n- Created a portfolio back-testing engine using Python and Alteryx to measure projected returns across 10+ fixed-income derivatives and ETF strategies using historical and benchmark return data\n- Streamlined client cash data management by implementing an automated data ingestion framework for uploading and downloading client data; projected to save 300 work hours annually"},{"key":"pacificcapital-201905","name":"Pacific Capital","date":"May 2019 - Aug. 2019","image":"static/media/pacificcapital.1e4f1b2e.png","position":"Quantitative Analytics Intern","team":"Portfolio Management","location":"Newport Beach, CA","detail":"- Designed reusable investment operations modules in Python that standardized Bloomberg feed parsing, computed market metrics, and automated recurring operations reporting\n- Architected and deployed an Oracle SQL database with ETL pipelines to consolidate financial data for 120+ clients from raw sources, automating data retrieval and eliminating manual data entry\n- Modeled tail-risk exposure using a volatility-weighted Python risk tool and regression analysis on historical market data under 10% S&P 500 decline scenarios"}],"hobbies":[{"key":"ski-200101","name":"Ski","image":"static/media/ski.0156853d.png","detail":"Hitting the slopes most winters — mostly groomers, occasionally chasing powder days.\n\n**Regular Resorts:**  \nBig Bear Mountain Resort  \nMammoth Mountain  \nKeystone Resort  \nNiseko United"},{"key":"badminton-200012","name":"Badminton","image":"static/media/badminton.61431557.png","detail":"Regular doubles player — always up for a fast rally."},{"key":"weight_training-200011","name":"Weight Training","image":"static/media/weight_training.17323d0b.png","detail":"Chasing progressive overload — see \"Protein for a Week\" in the PayPal menu."},{"key":"kendo-200010","name":"Kendo","image":"static/media/kendo.0dcfcec5.png","detail":"Nidan (二段, 2nd dan) in Japanese swordsmanship.\n\n**Highlights:**  \n2nd place, AUSKF state tournament (high school)\n\n**Previous Affiliations:**  \nAll United States Kendo Federation (AUSKF)"},{"key":"violin-200009","name":"Violin","image":"static/media/violin.8efc1721.png","detail":"Occasionally freelancing for special events. Privately taught violin for students aiming for honor orchestras.\n\n**Previous Affiliations:**  \nPacific Symphony Youth Orchestra  \nOrange County Youth Symphony Orchestra  \nCASMEC All-State High School Symphony Orchestra  \nSCSBOA