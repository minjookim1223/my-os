module.exports = {"bio":{"full_name":"Jay Kim","first_name":"Jay","last_name":"Kim","alias":"Jay","description":"Software Engineer building backend services and real-time data platforms, with a background spanning data engineering, machine learning, and cloud infrastructure.","avatar_url":"https://github.com/minjookim1223.png","theme_color":"#3D3D3D","location":"San Francisco, CA","email":"minjookim1223@gmail.com","phone":"(949) 812-2206","links":{"github":"https://github.com/minjookim1223","linkedin":"https://www.linkedin.com/in/minjookim1223","instagram":"https://www.instagram.com/balancedcolumns/","resume":"https://jaymkim.com/resume.pdf"},"skills":{"Python":"Expert","SQL":"Advanced","Java":"Advanced","JavaScript/TypeScript":"Advanced","C++":"Intermediate"}},"awards":[],"educations":[{"key":"gatech-202408","name":"Georgia Institute of Technology","image":"static/media/gatech.3f70bb53.png","degree":"Master of Science, Computer Science","detail":"Specialization in Artificial Intelligence","location":"Atlanta, GA","links":"[https://www.gatech.edu/](https://www.gatech.edu/)  \n[https://www.cc.gatech.edu/](https://www.cc.gatech.edu/)"},{"key":"usc-201708","name":"University of Southern California","image":"static/media/usc.18c3dc26.png","icon":"static/media/usc.icon.82965ccd.png","degree":"Bachelor of Science, Business Administration","detail":"Concentration in Data Science","location":"Los Angeles, CA","links":"[https://www.usc.edu/](https://www.usc.edu/)  \n[https://www.marshall.usc.edu/](https://www.marshall.usc.edu/)"},{"key":"ihs-201308","name":"Irvine High School","image":"static/media/ihs.71f898e7.png","degree":"High School Diploma","location":"Irvine, CA","link":"https://irvinehigh.iusd.org/"}],"projects":[],"workExperiences":[{"key":"qcells-202606","name":"Qcells","date":"June 2026 - Current","image":"static/media/qcells.0561f20f.png","website":"https://www.qcells.com","position":"Software Engineer","team":"Data & Real-Time Intelligence","location":"San Francisco, CA","detail":"- Developed backend services to ingest and expose real-time telemetry data from battery storage and grid assets, enabling monitoring and control across the platform\n- Designed and implemented Peak Demand API pipeline for battery, integrating data ingestion, time-series processing, PostgreSQL storage, and REST endpoints to surface peak load events for grid and battery management workflows\n- Built and deployed containerized platform services on Azure using Docker and Kubernetes, standardizing deployment for grid and battery management components\n- Implemented CI/CD pipelines with GitHub Actions and Azure Monitor/Application Insights observability for platform services, reducing deployment time and cutting incident detection time by 60%"},{"key":"stealthstartup-202309","name":"Stealth Startup","date":"Sep. 2023 - Feb. 2025","image":"static/media/stealthstartup.e6996a72.png","position":"Software Engineer","location":"Los Angeles, CA","detail":"- Led a start-up focused on streamlining the higher education process for international students by developing innovative solutions and tools that simplify applications, transfers, and enrollment workflows\n- Engineered a robust full-stack system using DRF (Python) and React (JavaScript), implementing a scalable student portfolio management pipeline and optimizing operational efficiency while seamlessly integrating the system across platforms\n- Developed and optimized back-testing engine (Python) to forecast student acceptance probabilities at targeted colleges, utilizing historical data and advanced algorithms to provide actionable insights for strategic application planning\n- Designed and structured the initial database using PostgreSQL to ensure efficient data handling, scalability, and performance, while implementing encryption and security protocols to protect sensitive information and ensure regulatory compliance"},{"key":"capitalone-202108","name":"Capital One","date":"Aug. 2021 - Aug. 2023","image"